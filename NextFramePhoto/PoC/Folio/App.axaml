<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Folio.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Folio/Assets/Styles/FolioTheme.axaml" />
        <StyleInclude Source="avares://Folio/Assets/Styles/Controls.axaml" />
    </Application.Styles>

</Application>
