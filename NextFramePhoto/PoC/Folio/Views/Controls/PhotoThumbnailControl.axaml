<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Folio.ViewModels"
             x:Class="Folio.Views.Controls.PhotoThumbnailControl"
             x:DataType="vm:PhotoViewModel"
             Cursor="Hand">

    <Border CornerRadius="{StaticResource Radius.Thumb}"
            ClipToBounds="True"
            x:Name="ThumbBorder">

        <!-- Thumbnail background (placeholder gradient until real image loads) -->
        <Panel>
            <Border x:Name="PlaceholderBg" />

            <!-- Hover overlay -->
            <Border x:Name="HoverOverlay"
                    Background="#99000000"
                    IsVisible="False"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch">
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="5"
                        Background="#AA000000"
                        CornerRadius="3"
                        Padding="5,2">
                    <TextBlock Text="{Binding Device.Name}"
                               FontSize="8"
                               Foreground="White" />
                </Border>
            </Border>

            <!-- Star indicator -->
            <TextBlock Text="★"
                       IsVisible="{Binding IsStarred}"
                       FontSize="11"
                       Foreground="{StaticResource Brush.Accent}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,5,4" />

            <!-- Selected ring -->
            <Border x:Name="SelectionRing"
                    BorderThickness="2"
                    BorderBrush="{StaticResource Brush.Accent}"
                    CornerRadius="{StaticResource Radius.Thumb}"
                    IsVisible="{Binding IsSelected}" />

            <!-- Camera label (bottom-left) -->
            <TextBlock Text="{Binding Device.Name}"
                       FontSize="8"
                       Foreground="#66FFFFFF"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Margin="5,0,0,4" />
        </Panel>
    </Border>

</UserControl>
