<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── FilterButton (toolbar pill) ────────────────────────────────── -->
    <Style Selector="Button.FilterButton">
        <Setter Property="Background"      Value="{StaticResource Brush.Surface2}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text2}" />
        <Setter Property="CornerRadius"    Value="{StaticResource Radius.Default}" />
        <Setter Property="Padding"         Value="11,4,11,4" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.FilterButton:pointerover">
        <Setter Property="Background"  Value="{StaticResource Brush.Surface3}" />
        <Setter Property="Foreground"  Value="{StaticResource Brush.Text}" />
    </Style>

    <Style Selector="Button.FilterButton.Active">
        <Setter Property="Background"  Value="{StaticResource Brush.Surface3}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentDim}" />
        <Setter Property="Foreground"  Value="{StaticResource Brush.Accent}" />
    </Style>

    <!-- ── ActionButton (detail panel) ────────────────────────────────── -->
    <Style Selector="Button.ActionButton">
        <Setter Property="Background"      Value="{StaticResource Brush.Surface2}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text2}" />
        <Setter Property="CornerRadius"    Value="{StaticResource Radius.Default}" />
        <Setter Property="Padding"         Value="8,7" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.ActionButton:pointerover">
        <Setter Property="Background" Value="{StaticResource Brush.Surface3}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    </Style>

    <Style Selector="Button.ActionButton.Primary">
        <Setter Property="Background"      Value="{StaticResource Brush.Accent}" />
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Accent}" />
        <Setter Property="Foreground"      Value="#FF111111" />
        <Setter Property="FontWeight"      Value="SemiBold" />
    </Style>

    <Style Selector="Button.ActionButton.Primary:pointerover">
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <!-- ── CatalogNowButton (inbox) ────────────────────────────────────── -->
    <Style Selector="Button.CatalogNowButton">
        <Setter Property="Background"      Value="{StaticResource Brush.Accent}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground"      Value="#FF111111" />
        <Setter Property="CornerRadius"    Value="{StaticResource Radius.Default}" />
        <Setter Property="Padding"         Value="12,6" />
        <Setter Property="FontSize"        Value="11" />
        <Setter Property="FontWeight"      Value="SemiBold" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.CatalogNowButton:pointerover">
        <Setter Property="Opacity" Value="0.88" />
    </Style>

    <!-- ── SectionLabel (DM Mono uppercase) ───────────────────────────── -->
    <Style Selector="TextBlock.SectionLabel">
        <Setter Property="FontSize"      Value="9" />
        <Setter Property="Foreground"    Value="{StaticResource Brush.Text3}" />
        <Setter Property="FontWeight"    Value="Normal" />
        <Setter Property="LetterSpacing" Value="1.4" />
    </Style>

    <!-- ── MonoLabel (metadata values) ─────────────────────────────────── -->
    <Style Selector="TextBlock.Mono">
        <Setter Property="FontSize"   Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text3}" />
    </Style>

    <!-- ── Separator line ──────────────────────────────────────────────── -->
    <Style Selector="Border.HRule">
        <Setter Property="Height"     Value="1" />
        <Setter Property="Background" Value="{StaticResource Brush.Border}" />
        <Setter Property="Margin"     Value="0" />
    </Style>

    <Style Selector="Border.VRule">
        <Setter Property="Width"      Value="1" />
        <Setter Property="Background" Value="{StaticResource Brush.Border}" />
    </Style>

    <!-- ── DeviceToggle (CheckBox styled as toggle) ────────────────────── -->
    <Style Selector="ToggleButton.DeviceToggle">
        <Setter Property="Width"      Value="28" />
        <Setter Property="Height"     Value="16" />
        <Setter Property="Cursor"     Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Track"
                        Width="28" Height="16"
                        CornerRadius="8"
                        Background="{StaticResource Brush.Surface3}">
                    <Ellipse x:Name="Thumb"
                             Width="12" Height="12"
                             Fill="White"
                             HorizontalAlignment="Left"
                             Margin="2,0,0,0" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.DeviceToggle:checked /template/ Border#Track">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
    </Style>

    <Style Selector="ToggleButton.DeviceToggle:checked /template/ Ellipse#Thumb">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Margin"              Value="0,0,2,0" />
    </Style>

</Styles>
